# Copy to .env.local and fill in. All VITE_* vars are exposed to the browser
# (that's fine — the anon key is public and gated by Row Level Security).

# --- Supabase (browser) ---
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Server-only secrets (NEVER prefix with VITE_, never commit) ---
# Used by the seed script (scripts/seed-auth.mjs) and the /api/admin function.
# SUPABASE_URL is the same URL as VITE_SUPABASE_URL, just without the VITE_ prefix
# so Node scripts and serverless functions can read it.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- AI proxy (/api/claude), server-only ---
ANTHROPIC_API_KEY=
# Optional. Defaults to claude-opus-4-8. Use claude-sonnet-5 or claude-haiku-4-5
# for a cheaper note helper.
ANTHROPIC_MODEL=
