# Copy to .env.local and fill in. All VITE_* vars are exposed to the browser
# (that's fine — the anon key is public and gated by Row Level Security).

# --- Supabase (browser) ---
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Bootstrap Main Admin (the one seeded account) ---
# The app seeds a single Main Admin profile into crm-users on first run from
# these VITE_* vars, so someone can log in and create everyone else in-app.
VITE_BOOTSTRAP_ADMIN_EMAIL=
VITE_BOOTSTRAP_ADMIN_NAME=

# --- Server-only secrets (NEVER prefix with VITE_, never commit) ---
# Used by the seed script (scripts/seed-auth.mjs) and the /api/admin function.
# SUPABASE_URL is the same URL as VITE_SUPABASE_URL, just without the VITE_ prefix
# so Node scripts and serverless functions can read it.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# The bootstrap admin's Supabase Auth login is created by seed-auth.mjs from
# these. BOOTSTRAP_ADMIN_EMAIL must match VITE_BOOTSTRAP_ADMIN_EMAIL above.
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=

# --- AI proxy (/api/claude), server-only ---
ANTHROPIC_API_KEY=
# Optional. Defaults to claude-opus-4-8. Use claude-sonnet-5 or claude-haiku-4-5
# for a cheaper note helper.
ANTHROPIC_MODEL=
